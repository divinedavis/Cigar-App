# Copy to scripts/scraper.env (gitignored) and fill in.
# The service_role key is required for Storage writes; the publishable/anon
# key only works if you've opened the bucket's RLS policies explicitly.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service_role_or_publishable_key>
SUPABASE_BUCKET=cigars
